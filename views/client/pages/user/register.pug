extends ../../layouts/default.pug
include ../../mixins/show-alert.pug

block main 
    +alert-errol(5000)

    .container.py-5
        .row.justify-content-center
            .col-md-6.col-lg-5
                .card.shadow-sm
                    .card-body.p-4
                        h3.text-center.mb-4 Đăng ký tài khoản

                        form(action="/user/register" method="POST")
                            .mb-3
                                label.form-label(for="fullname") Họ và tên
                                input.form-control(type="text" id="fullname" name="fullname" placeholder="Nhập họ và tên" required)

                            .mb-3
                                label.form-label(for="email") Email
                                input.form-control(type="email" id="email" name="email" placeholder="Nhập email" required)

                            .mb-3
                                label.form-label(for="password") Mật khẩu
                                input.form-control(type="password" id="password" name="password" placeholder="Nhập mật khẩu" required)

                            button.btn.btn-primary.w-100(type="submit") Đăng ký