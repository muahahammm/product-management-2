extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
    .product-detail
        .container.my-5
            .row.g-4

                // LEFT - IMAGE
                .col-lg-5
                    .product-gallery
                        .main-image
                            img(src=product.thumbnail alt=product.title)

                        .thumb-list.mt-3
                            img(src=product.thumbnail)
                            img(src=product.thumbnail)
                            img(src=product.thumbnail)
                            img(src=product.thumbnail)

                // RIGHT - INFO
                .col-lg-7
                    h1.product-title #{product.title}

                    if(product.category)
                        .product-category
                            span Danh mục:
                            a(href=`/products/${product.category.slug}`) #{product.category.title}

                    .price-box
                        if(product.priceNew)
                            .price-new #{product.priceNew}$

                        if(product.price)
                            .price-old #{product.price}$

                        if(product.discountPercentage)
                            .discount -#{product.discountPercentage}%

                    if(product.stock)
                        .stock
                            | Còn lại:
                            span #{product.stock}
                            |  sản phẩm

                    form.buy-box(action=`/cart/add/${product.id}` method="POST")
                        input.form-control.quantity(
                            type="number"
                            name="quantity"
                            value="1"
                            min="1"
                            max=product.stock
                        )
                        button.btn.btn-success.btn-lg(type="submit") Thêm vào giỏ

                    // Promotion
                    .promo-box.mt-4
                        h5 Khuyến mãi
                        ul
                            li Tặng phiếu mua hàng 10$
                            li Miễn phí giao hàng
                            li Bảo hành 12 tháng

        hr

        .container.my-5
            .row
                .col-12
                    +box-head("Mô tả sản phẩm")
                    .product-desc !{product.description}