extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
    .container.my-3 
        .row
            .col-12 
                +box-head("Chat")

        .row
            .col-12 
                .chat 
                    .inner-body 
                        each chat in chats 
                            div(class=(chat.user_id == user.id ? "inner-outgoing" : "inner-incoming"))
                                if(chat.user_id != user.id)
                                    .inner-name #{chat.infoUser.fullname}
                                .inner-content 
                                    | #{chat.content}

                        //- .inner-incoming
                        //-     .inner-name Nam 
                        //-     .inner-content 
                        //-         | Oh my god 
                        //- .inner-outgoing
                        //-     .inner-name Minh
                        //-     .inner-content 
                        //-         | OK
                    .inner-foot 
                        form(class="inner-form" action="")
                            input(type="text" placeholder="Nhập nội dung" name="content")
                            button(type="submit") 
                                i.fa-solid.fa-paper-plane    