extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
    .container.my-3 

        .row 
            .col-12 
                +box-head("Danh sách người dùng")

        .row 
            each user in users
                .col-3                 
                    div(class="box-user")
                        div(class="inner-avatar")
                            img(src=user.avatar alt=user.fullname)
                        div(class="inner-info")
                            div(class="inner-name") #{user.fullname}
                            div(class="inner-buttons")
                                button(class="btn btn-sm btn-primary mr-1" btn-add-friend=user.id) Kết bạn 
                                button(class="btn btn-sm btn-secondary mr-1" btn-cancel-friend=user.id) Hủy yêu cầu

                                //- button(class="btn btn-sm btn-primary mr-1" btn-accept-friend=user.id) Chấp nhận 
                                //- button(class="btn btn-sm btn-secondary mr-1" btn-refuse-friend=user.id) Xóa
                                //- button(class="btn btn-sm btn-secondary mr-1" btn-deleted-friend=user.id disabled) Đã xóa