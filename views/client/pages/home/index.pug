    .section-products-featured.my-5
        .container
            .row
                .col-12
                    +box-head("Sản phẩm nổi bật")
                
            .row
                +product-grid(productsFeature)
    
    .section-products-new.my-5
        .container
            .row
                .col-12
                    +box-head("Sản phẩm mới")
                
            .row
                +product-grid(productsNew)