extends ../../layouts/default.pug
include ../../mixins/no-permission.pug

block main
    if(role.permissions.includes("article_category_create"))
        .container.mt-4
            .row.g-4.category-detail-wrapper
                .col-md-5
                    .category-card.category-image-card
                        if(article.media)
                            img.category-image(
                                src=article.media
                                alt=article.title
                            )
                        else
                            .no-image Không có hình ảnh

                .col-md-7
                    .category-card.category-info-card
                        if(article.title)
                            h1.category-title #{article.title}

                        if(article.status)
                            .category-item
                                span.label Trạng thái:
                                if (article.status === "active")
                                    span.badge.bg-success Hoạt động
                                else
                                    span.badge.bg-danger Dừng hoạt động

                        if(article.position)
                            .category-item
                                span.label Vị trí:
                                b #{article.position}

                        if(article.description)
                            .category-description
                                span.label Mô tả:
                                .desc-content !{article.description}

                        a.btn.btn-warning.mt-3(
                            href=`${prefixAdmin}/products-category/edit/${article.id}`
                        ) Chỉnh sửa
    else 
        +no-permission()