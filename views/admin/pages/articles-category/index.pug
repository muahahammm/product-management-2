extends ../../layouts/default.pug
include ../../mixins/no-permission.pug
include ../../mixins/search.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/show-alert.pug
include ../../mixins/formatTime.pug
include ../../mixins/table-tree.pug

block main
    +alert-success(5000)
    +alert-errol(5000)

    h1(class="mb-4") Danh mục bài viết

    .card.mb-3
        .card-header Tìm kiếm 
        .card-body 
            .row
                .col-6 
                    +search(keyword)

    .card.mb-3 
        .card-header Danh sách 
        .card-body
            .row 
                .col-8
                    +form-change-multi(`${prefixAdmin}/articles-category/change-multi?_method=PATCH`)
                .col-4.text-right 
                    a(href=`${prefixAdmin}/articles-category/create` class="btn btn-outline-success") + Thêm mới

            table(class="table table-hover table-sm" checkbox-multi) 
                thead 
                    tr  
                        th 
                            input(type="checkbox" name="checkall")
                        th STT  
                        th Ảnh
                        th Tiêu đề
                        th Vị trí
                        th Trạng thái
                        th Người tạo
                        th Người cập nhật 
                        th Hành động 
            
                tbody
                - const path = "articles-category"
                    +table-tree-article(record, path) 

    form(action="", method="POST" id="form-change-status" data-path=`${prefixAdmin}/articles-category/change-status`) 
    form(action="", method="POST" id="form-delete-item" data-path=`${prefixAdmin}/articles-category/delete`)

    script(src="/admin/js/Article.js") 
    