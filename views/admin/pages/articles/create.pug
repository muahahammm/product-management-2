extends ../../layouts/default.pug
include ../../mixins/no-permission.pug
include ../../mixins/select-tree.pug

block main
    h1(class="mb-4") Thêm mới bài viết

    form(action=`${prefixAdmin}/articles/create` method="POST")
        div(class="form-group")
            label(for="title") Tiêu đề *
            input(type="text" class="form-control" id="title" name="title" required)

        div(class="form-group")
            label(for="article_category_id") Danh mục cha 
            select(name="article_category_id" id="article_category_id" class="form-control")
                option(value="") --Chọn danh mục cha--
                if(category)
                    +select-tree(category) 

        div(class="form-group" upload-image)
            label(for="media") Ảnh *
            input(type="file" class="form-control-file" id="media" name="media" accept="image/*" upload-image-input)
            div(class="image-preview-wrapper")
                img(src="" upload-image-preview class="image-preview")
                button(type="button" class="btn-close" aria-label="Close" button-close)

        div(class="form-group")
            label(for="desc") Mô tả ngắn *
            textarea(class="form-control textarea-tinymce" id="desc" name="description" rows="4") 

        div(class="form-group")
            label(for="content") Nội dung *
            textarea(class="form-control textarea-tinymce" id="content" name="content" rows="4")

        div(class="form-group")
            label(for="position") Vị trí 
            input(type="number" class="form-control" id="position" name="position" placeholder="Tự động tăng" min="1")

        div(class="form-group form-check form-check-inline")
            input(type="radio" class="form-check-input" id="statusActive" name="status" value="active" checked)
            label(for="statusActive" class="form-check-label") Hoạt động
        
        div(class="form-group form-check form-check-inline")
            input(type="radio" class="form-check-input" id="statusInActive" name="status" value="inactive")
            label(for="statusActive" class="form-check-label") Dừng hoạt động

        div(class="form-group")
            button(type="submit" class="btn btn-primary") Tạo mới