extends ../../layouts/default.pug
include ../../mixins/no-permission.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/sort.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/show-alert.pug
include ../../mixins/formatTime.pug

block main
    +alert-success(5000)
    +alert-errol(5000)

    h1(class="mb-4") Danh sách bài viết

    .card.mb-3
        .card-header Bộ lọc và tìm kiếm 
        .card-body 
            .row
                .col-6
                    +filter-status(filterStatus)
                .col-6 
                    +search(keyword)

    .card.mb-3 
        .card-header Sắp xếp 
        .card-body 
            +sort-product-category()

    .card.mb-3 
        .card-header Danh sách 
        .card-body
            .row 
                .col-8
                    +form-change-multi(`${prefixAdmin}/articles/change-multi?_method=PATCH`)
                .col-4.text-right 
                    a(href=`${prefixAdmin}/articles/create` class="btn btn-outline-success") + Thêm mới

            table(class="table table-hover table-sm" checkbox-multi) 
                thead 
                    tr  
                        th 
                            input(type="checkbox" name="checkall")
                        th STT  
                        th Tiêu đề 
                        th Ảnh 
                        th Vị trí
                        th Trạng thái
                        th Người tạo
                        th Người cập nhật 
                        th Hành động 
            
                tbody
                    each item, index in records
                        tr 
                            td 
                                input(type="checkbox" name="id" value = item.id)
                            td #{index + 1}
                            td #{item.title} 
                            td 
                                img(src=item.media alt=item.title width="100px" height="50px")
                            td 
                                input(
                                        type="number"
                                        value=item.position 
                                        style="width: 50px"
                                        min="1"
                                        name="position"
                                    )
                            td 
                                if(item.status === "active")
                                    a(
                                        href="javascript:;" 
                                        data-status=item.status
                                        data-id=item.id
                                        button-change-status 
                                        class="isactive"
                                    ) Hoạt động
                                else
                                    a(
                                        href="javascript:;" 
                                        data-status=item.status
                                        data-id=item.id 
                                        button-change-status 
                                        class="isinactive"
                                    ) Dừng hoạt động
                            td 
                                span #{item.createdBy.accountFullName}
                                p
                                    +formatDateTime(item.createdBy.createdAt)
                            td 
                                - const updatedBy = item.updatedBy.slice(-1)[0]
                                if(updatedBy)
                                    span #{updatedBy.accountFullName}
                                    p
                                        +formatDateTime(updatedBy.updatedAt)
                            td  
                               
                                a(href=`${prefixAdmin}/articles/detail/${item.id}` class="btn btn-secondary btn-sm") Chi tiết
                            
                                a(href=`${prefixAdmin}/articles/edit/${item.id}` class="btn btn-warning btn-sm") Sửa 
                            
                                button(class="btn btn-danger btn-sm ml-1" button-delete data-id=item.id) Xóa
    
    +pagination(pagination)

    form(action="", method="POST" id="form-change-status" data-path=`${prefixAdmin}/articles/change-status`) 
    form(action="", method="POST" id="form-delete-item" data-path=`${prefixAdmin}/articles/delete`)

    script(src="/admin/js/Article.js") 
    