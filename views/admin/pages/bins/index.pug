extends ../../layouts/default.pug
include ../../mixins/search.pug
include ../../mixins/show-alert.pug
include ../../mixins/no-permission.pug
include ../../mixins/table-tree.pug

block main 
    h1(class="mb-4") Thùng rác 

    +alert-success(5000)
    +alert-errol(5000)

    .card.mb-3
        .card-header Danh sách sản phẩm  
        .card-body
            table(class="table table-hover table-sm" checkbox-multi) 
                thead 
                    tr  
                        th 
                            input(type="checkbox" name="checkall")
                        th STT 
                        th Hình ảnh 
                        th Tiêu đề 
                        th Giá 
                        th Vị trí
                        th Trạng thái 
                        th Hành động  
                
                tbody
                    each item, index in products
                        tr 
                            td 
                                input(type="checkbox" name="id" value = item.id)
                            td #{index + 1} 
                            td 
                                img(src=item.thumbnail alt=item.title width="100px" height="50px")
                            td #{item.title} 
                            td #{item.price}$
                            td 
                                input(
                                    type="number"
                                    value=item.position 
                                    style="width: 50px"
                                    min="1"
                                    name="position"
                                )
                            td
                                    if(item.status == "active")
                                        a(class="isactive") Hoạt động
                                    else
                                        a(class="isinactive") Dừng hoạt động
                            td
                                a(href=`${prefixAdmin}/products/edit/${item.id}` class="btn btn-info btn-sm") Khôi phục 
    
    .card.mb-3
        .card-header Danh mục sản phẩm  
        .card-body
            table(class="table table-hover table-sm" checkbox-multi) 
                thead 
                    tr  
                        th 
                            input(type="checkbox" name="checkall")
                        th STT 
                        th Hình ảnh 
                        th Tiêu đề 
                        th Vị trí
                        th Trạng thái 
                        th Hành động  
                
                tbody
                    +table-tree-bin(productscategory)
    
    .card.mb-3
        .card-header Danh sách tài khoản quản trị
        .card-body
            table(class="table table-hover table-sm" checkbox-multi) 
                thead 
                    tr  
                        th 
                            input(type="checkbox" name="checkall")
                        th STT 
                        th Hình ảnh 
                        th Họ tên 
                        th Quyền 
                        th Email
                        th Trạng thái 
                        th Hành động  
                
                tbody
                    each item, index in accounts, roles
                        tr 
                            td 
                                input(type="checkbox" name="checkall")
                            td #{index + 1}
                            td 
                                img(src=item.avatar alt=item.fullname width="100px" height="50px")
                            td #{item.fullname} 
                            td #{item.role.title}
                            td #{item.email}
                            td
                                if(item.status === "active")
                                    a(class="isactive") Hoạt động
                                else
                                    a(class="isinactive") Dừng hoạt động
                            td  
                                a(href=`${prefixAdmin}/accounts/detail/${item.id}` class="btn btn-info btn-sm") Khôi phục
    
    .card.mb-3
        .card-header Danh sách tài khoản người dùng
        .card-body
            table(class="table table-hover table-sm" checkbox-multi) 
                thead 
                    tr  
                        th 
                            input(type="checkbox" name="checkall")
                        th STT 
                        th Tên 
                        th Email 
                        th Trạng thái 
                        th Hành động 
                
                tbody
                    each item, index in users
