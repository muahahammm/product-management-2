    .card.mb-3
        .card-header Danh sách bài viết 
        .card-body
            table(class="table table-hover table-sm" checkbox-multi) 
                thead 
                    tr  
                        th 
                            input(type="checkbox" name="checkall")
                        th STT  
                        th Ảnh 
                        th Tiêu đề
                        th Vị trí
                        th Trạng thái
                        th Hành động
                
                tbody
                    each item, index in articles
                        tr 
                            td 
                                input(type="checkbox" name="id" value = item.id)
                            td #{index + 1}
                            td 
                                img(src=item.media alt=item.title width="100px" height="50px") 
                            td #{item.title}
                            td 
                                input(
                                        type="number"
                                        value=item.position 
                                        style="width: 50px"
                                        min="1"
                                        name="position"
                                    )
                            td 
                                if(item.status == "active")
                                    a(class="isactive") Hoạt động
                                else
                                    a(class="isinactive") Dừng hoạt động
                            td  
                                a(href=`${prefixAdmin}/articles/detail/${item.id}` class="btn btn-info btn-sm") Khôi phục

    .card.mb-3
        .card-header Danh mục bài viết 
        .card-body
            table(class="table table-hover table-sm" checkbox-multi) 
                thead 
                    tr  
                        th 
                            input(type="checkbox" name="checkall")
                        th STT  
                        th Ảnh
                        th Tiêu đề
                        th Vị trí
                        th Trạng thái
                        th Hành động
                
                tbody
                - const path = "articles-category"
                    +table-tree-article-bin(articlecategory, path) 
    
    .card.mb-3
        .card-header Nhóm quyền 
        .card-body
            table(class="table table-hover table-sm" checkbox-multi) 
                thead 
                    tr  
                        th STT 
                        th Nhóm quyền
                        th Mô tả ngắn 
                        th Hành động 
                
                tbody
                    each item, index in roles 
                        tr 
                            td #{index + 1}
                            td #{item.title}
                            td #{item.description}  
                            td 
                                a(href=`${prefixAdmin}/roles/detail/${item.id}` class="btn btn-info btn-sm") Khôi phục