extends ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/show-alert.pug
include ../../mixins/sort.pug
include ../../mixins/no-permission.pug
include ../../mixins/formatTime.pug

block main
    if(role.permissions.includes("user_view"))
        +alert-success(5000)
        +alert-errol(5000)

        h1 Danh sách tài khoản người dùng

        .card.mb-3
            .card-header Bộ lọc và tìm kiếm 
            .card-body 
                .row
                    .col-6
                        +filter-status(filterStatus)
                    .col-6 
                        +search(keyword)

        .card.mb-3 
            .card-header Sắp xếp 
            .card-body 
                +sort-user()

        
        .card.mb-3
            .card-header Danh sách tài khoản 
            .card-body
                .row 
                    if(role.permissions.includes("user_edit"))
                        .col-8
                            +form-change-multi-user(`${prefixAdmin}/users/change-multi?_method=PATCH`)

                table(class="table table-hover table-sm" checkbox-multi) 
                    thead 
                        tr  
                            th 
                                input(type="checkbox" name="checkall")
                            th STT 
                            th Tên 
                            th Email 
                            th Trạng thái 
                            th Ngày tạo 
                            th Người cập nhật
                            th Hành động
                
                    tbody
                        each item, index in users
                            tr 
                                td 
                                    input(type="checkbox" name="id" value = item.id)
                                td #{index + 1}
                                td #{item.fullname} 
                                td #{item.email}
                                td
                                    if(item.status == "active")
                                        a(
                                            href="javascript:;" 
                                            data-status=item.status
                                            data-id=item.id
                                            button-change-status 
                                            class="isactive"
                                        ) Hoạt động
                                    else
                                        a(
                                            href="javascript:;" 
                                            data-status=item.status
                                            data-id=item.id 
                                            button-change-status 
                                            class="isinactive"
                                        ) Dừng hoạt động                       
                                td 
                                    +formatDateTime(item.createdAt)
                                td 
                                    - const updatedBy = item.updatedBy.slice(-1)[0]
                                    if(updatedBy)
                                        span #{updatedBy.accountFullName}
                                        p
                                            +formatDateTime(updatedBy.updatedAt)
                                if(role.permissions.includes("user_delete"))
                                    td
                                        button(class="btn btn-danger btn-sm ml-1" button-delete data-id=item.id) Xóa

        +pagination(pagination)

        form(action="", method="POST" id="form-change-status" data-path=`${prefixAdmin}/users/change-status`) 
        form(action="", method="POST" id="form-delete-item" data-path=`${prefixAdmin}/users/delete`)

        script(src="/admin/js/product.js")
    else 
        +no-permission()